# =============================================================================
# adaptive-island .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Node/TypeScript
# ---------------------------------------------------------------------------
node_modules/
dist/
build/
out/
*.tsbuildinfo
.tsbuildinfo
.npm/
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
.Python
.python-version
pip-wheel-metadata/
pip-log.txt
.venv/
venv/
env/
ENV/
.pyenv/
.pdm-build/
__pypackages__/

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/
.tox/
.nox/
.cache/
coverage/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
junit.xml

# ---------------------------------------------------------------------------
# Env/secrets (NEVER commit)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
!.env.template
.sentryclirc
.sentryclirc.*
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/
*.local

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# Editor/IDE
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.iml
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# ML/Databricks artifacts
# ---------------------------------------------------------------------------
mlflow.db
mlruns/
mlartifacts/
.databricks/
.databricks-cli/

# ---------------------------------------------------------------------------
# Data/model files (never commit large binaries)
# ---------------------------------------------------------------------------
*.parquet
*.csv.gz
*.npz
*.pkl
*.joblib
*.h5
*.onnx
*.pt
*.pth
*.bin
*.safetensors
data/
models/
checkpoints/

# ---------------------------------------------------------------------------
# Local dev/docker volumes
# ---------------------------------------------------------------------------
examples/docker-compose-local/volumes/
docker-compose.override.yml
*.sqlite
*.sqlite3
*.db
!mlflow.db.example
# Build artifacts
dist/
build/
*.egg-info/
__pycache__/
*.pyc
node_modules/
.pnp.*
.yarn/

# Local dev volumes
examples/docker-compose-local/volumes/

# Editor
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# MLflow local backing store
mlflow.db
mlruns/
